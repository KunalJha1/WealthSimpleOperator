# Backend Configuration

# AI Provider: mock or gemini
PROVIDER=mock

# Gemini API Key (only needed if PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Uvicorn Server Configuration
# Host: 0.0.0.0 for all interfaces (production), 127.0.0.1 for localhost only
UVICORN_HOST=0.0.0.0

# Port
UVICORN_PORT=8001

# Enable auto-reload during development (set to 1 for dev, empty for production)
UVICORN_RELOAD=
